{
  "name": "runebase-explorer-daemon",
  "private": true,
  "version": "0.1.0",
  "description": "Blockchain indexer for the Runebase network",
  "main": "src/index.mjs",
  "scripts": {
    "build": "rm -rf dist && babel src --out-dir dist --copy-files --keep-file-extension",
    "start": "node --experimental-specifier-resolution=node dist/index.mjs start",
    "dev": "nodemon --experimental-specifier-resolution=node --exec babel-node src/index.mjs start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:status": "sequelize-cli db:migrate:status",
    "release:patch": "npm version patch -m 'chore(release): bump to v%s' && npm run build",
    "release:minor": "npm version minor -m 'chore(release): bump to v%s' && npm run build",
    "release:major": "npm version major -m 'chore(release): bump to v%s' && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runebase/runebase-explorer-daemon.git"
  },
  "keywords": [
    "runebase",
    "runebase-explorer-daemon",
    "runebase explorer"
  ],
  "author": "RUNEBASE <foundation@runebase.org>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/runebase/runebase-explorer-daemon/issues"
  },
  "homepage": "https://github.com/runebase/runebase-explorer-daemon#readme",
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/node": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.2"
  },
  "dependencies": {
    "colors": "^1.4.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ethereumjs-abi": "^0.6.8",
    "lru-cache": "^11.2.7",
    "mysql2": "^3.20.0",
    "secp256k1": "^5.0.1",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0"
  }
}
